# Telegram Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHANNEL_ID=your_channel_id_here
# Comma-separated list of Telegram user IDs
ALLOWED_USER_IDS=12345678,87654321

# Immich Configuration
IMMICH_URL=https://your-immich-instance.com
IMMICH_API_KEY=your_immich_api_key_here

# Optional: Album name pattern, e.g., "{year}/{month}"
# {month} will be replaced by the full month name in English
# {year} will be replaced by the 4-digit year
ALBUM_NAME_PATTERN={year}/{month}
